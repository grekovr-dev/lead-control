# Production env contract for lead-control.
# Real values must live on the VPS in .env.production and must not be committed to Git.

APP_NAME=lead-control
APP_ENV=production
APP_KEY=base64:CHANGE_ME
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=Europe/Kyiv
LETS_ENCRYPT_PRIMARY_DOMAIN=example.com
LETS_ENCRYPT_DOMAINS=example.com,www.example.com
LETS_ENCRYPT_EMAIL=admin@example.com
APP_LOCALE=uk
APP_FALLBACK_LOCALE=uk
APP_FAKER_LOCALE=uk_UA
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=lead_control
DB_USERNAME=lead_control
DB_PASSWORD=CHANGE_ME

MYSQL_DATABASE=lead_control
MYSQL_USER=lead_control
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

CACHE_STORE=redis
CACHE_PREFIX=lead-control-cache-

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_COOKIE=lead-control-session

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_LOG_CHANNEL=stack
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=
TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_TIMEOUT_SECONDS=10

BACKOFFICE_ADMIN_NAME="Backoffice Admin"
BACKOFFICE_ADMIN_EMAIL=grekovr@gmail.com
BACKOFFICE_ADMIN_PASSWORD=CHANGE_ME
BACKOFFICE_MANAGER_NAME="Backoffice Manager"
BACKOFFICE_MANAGER_EMAIL=potapov@gmail.com
BACKOFFICE_MANAGER_PASSWORD=CHANGE_ME

HORIZON_NAME=lead-control
HORIZON_DOMAIN=null
HORIZON_PATH=horizon
HORIZON_PREFIX=lead_control_horizon:
HORIZON_MEMORY_LIMIT=128
HORIZON_BALANCE=simple
HORIZON_MAX_PROCESSES=1
HORIZON_WORKER_MEMORY=128
HORIZON_TRIES=3
HORIZON_TIMEOUT=60
