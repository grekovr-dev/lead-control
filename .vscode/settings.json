{
  // ===== Общие удобства =====
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  // ===== PHP (используем PHP из Docker) =====
  "php.validate.executablePath": "${workspaceFolder}/.vscode/php-docker.sh",
  "intelephense.environment.phpVersion": "8.3.0",
  "intelephense.files.maxSize": 5000000,
  // Чтобы Intelephense не ел мозг из-за vendor/временных файлов
  "intelephense.files.exclude": [
    "**/.git/**",
    "**/node_modules/**",
    "**/storage/**",
    "**/bootstrap/cache/**",
    "**/.idea/**"
  ],
  // ключевое: автозагрузка из Laravel-проекта
  "intelephense.environment.includePaths": [
    "apps/web/vendor",
    "apps/web",
    "src"
  ],
  // ===== Blade / Laravel =====
  "[blade]": {
    "editor.formatOnSave": true
  },
  // ===== Pint (Laravel) =====
  "terminal.integrated.env.linux": {
    "PROJECT_ROOT": "${workspaceFolder}"
  },
  // ===== Docker =====
  "docker.composeCommand": "docker compose",
  // ===== Поиск/исключения =====
  "search.exclude": {
    "**/apps/web/vendor": true,
    "**/apps/web/storage": true,
    "**/apps/web/bootstrap/cache": true,
    "**/node_modules": true
  },
  // ===== CSS =====
  "css.customData": [
    ".vscode/css-custom-data.json"
  ],
  // ===== PHPUnit Test Explorer =====
  // Для docker path mapping используем абсолютный путь: ${workspaceFolder}
  // в phpunit.paths у этого расширения работает нестабильно.
  "phpunit.command": "docker compose exec -T app ${php} ${phpargs} ${phpunit} ${phpunitargs}",
  "phpunit.php": "php",
  "phpunit.phpunit": "/var/www/apps/web/vendor/bin/phpunit",
  "phpunit.args": [
    "-c",
    "/var/www/apps/web/phpunit.xml"
  ],
  "phpunit.debuggerConfig": "Listen Xdebug (Docker Tests)",
  "phpunit.xdebugPort": 9003,
  "phpunit.paths": {
    "/home/hrekov-r/Projects/lead-control": "/var/www"
  }
}
