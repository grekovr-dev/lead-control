{
  // ===== Общие удобства =====
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  // ===== PHP (используем PHP из Docker) =====
  "php.validate.executablePath": "${workspaceFolder}/.vscode/php-docker.sh",
  "intelephense.environment.phpVersion": "8.3.0",
  "intelephense.files.maxSize": 5000000,
  // Чтобы Intelephense не ел мозг из-за vendor/временных файлов
  "intelephense.files.exclude": [
    "**/.git/**",
    "**/node_modules/**",
    "**/storage/**",
    "**/bootstrap/cache/**",
    "**/vendor/**",
    "**/.idea/**"
  ],
  // ключевое: автозагрузка из Laravel-проекта
  "intelephense.environment.includePaths": [
    "apps/web/vendor",
    "apps/web",
    "src"
  ],
  // ===== Blade / Laravel =====
  // Форматирование Blade (если у тебя Blade Formatter / Laravel Blade Formatter)
  // (если один из этих плагинов использует другие ключи — скажешь, подправлю под точное расширение)
  "[blade]": {
    "editor.formatOnSave": true
  },
  // ===== Pint (Laravel) =====
  // запускать Pint проще через задачи, но оставим подсказку:
  "terminal.integrated.env.linux": {
    "PROJECT_ROOT": "${workspaceFolder}"
  },
  // ===== Docker =====
  "docker.composeCommand": "docker compose",
  // ===== Поиск/исключения =====
  "search.exclude": {
    "**/apps/web/vendor": true,
    "**/apps/web/storage": true,
    "**/apps/web/bootstrap/cache": true,
    "**/node_modules": true
  },
  // ===== CSS =====
  "css.customData": [
    ".vscode/css-custom-data.json"
  ]
}
